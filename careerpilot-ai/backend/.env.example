# LLM Provider keys (set at least one)
GOOGLE_API_KEY=google api key
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Database
DATABASE_URL=sqlite:///./careerpilot.db

# Vector store
CHROMA_PERSIST_DIR=./chroma_db

# LangSmith observability (set to false unless you have a LangSmith key)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=careerpilot-ai

# Notifications (all optional - leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Job search APIs (optional)
JOB_SEARCH_API_KEY=job_search_api_key
# Real job search via JSearch (RapidAPI). Get a free key at:
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=job_search_api_key
# App
APP_ENV=development
SECRET_KEY=change_me_in_production
